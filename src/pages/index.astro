---
import '../styles/scroll-slides.css';
const base = import.meta.env.BASE_URL;
const nav = [
  ['خانه',0,'home'],['خدمات',1,'services'],['نمونه‌کارها',1,'work'],
  ['قیمت‌ها',1,'pricing'],['درباره‌ما',2,'about'],['تماس با ما',2,'contact']
];
const services = [
  ['طراحی و توسعه وب‌سایت','◎'],['طراحی UI/UX','✎'],['پنل و ابزارهای اختصاصی','⚙'],
  ['خودکارسازی فرآیندها','⌘'],['بهینه‌سازی و بهبود عملکرد','↗'],['پشتیبانی و توسعه','◉']
];
---
<!doctype html>
<html lang="fa" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="theme-color" content="#ffffff" />
  <meta name="description" content="وبیگرام؛ از طرح مدادی تا اجرای واقعی ایده‌های دیجیتال." />
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <title>وبیگرام | از ایده تا اجرای واقعی</title>
</head>
<body data-stage="0">
  <div class="slide-loader" id="loader"><div>در حال آماده‌سازی طرح‌ها<div class="loader-line"></div></div></div>
  <main class="story" id="story">
    <i class="anchor a1" id="sketch"></i><i class="anchor a2" id="color"></i><i class="anchor a3" id="real"></i>
    <div class="viewport">
      <div class="frame">
        <svg width="0" height="0" aria-hidden="true" style="position:absolute">
          <filter id="pencil-rough"><feTurbulence type="fractalNoise" baseFrequency=".014" numOctaves="2" seed="7" result="noise"/><feDisplacementMap in="SourceGraphic" in2="noise" scale=".65"/></filter>
        </svg>

        <section class="slide slide-sketch active" data-slide="0">
          <div class="visual visual-sketch">
            <div class="sketch-composition" aria-label="اجزای مستقل طرح اولیه وبیگرام">
              <div class="sketch-paper" aria-hidden="true"></div>
              <div class="construction-line line-v1" aria-hidden="true"></div>
              <div class="construction-line line-v2" aria-hidden="true"></div>
              <div class="construction-line line-h1" aria-hidden="true"></div>
              <div class="construction-line line-h2" aria-hidden="true"></div>

              <svg class="sketch-connectors" viewBox="0 0 1000 900" fill="none" aria-hidden="true">
                <path class="wire wire-1" d="M248 126C310 129 333 173 368 232" />
                <path class="wire wire-2" d="M675 108C625 123 599 165 575 231" />
                <path class="wire wire-3" d="M150 350C221 350 258 356 315 370" />
                <path class="wire wire-4" d="M188 617C243 580 265 540 303 502" />
                <path class="wire wire-5" d="M517 780C525 728 523 680 512 625" />
                <path class="wire wire-dash" d="M570 758C675 790 767 755 847 680" />
                <circle cx="248" cy="126" r="5"/><circle cx="368" cy="232" r="5"/>
                <circle cx="675" cy="108" r="5"/><circle cx="575" cy="231" r="5"/>
                <circle cx="150" cy="350" r="5"/><circle cx="315" cy="370" r="5"/>
                <circle cx="188" cy="617" r="5"/><circle cx="303" cy="502" r="5"/>
                <circle cx="517" cy="780" r="5"/><circle cx="512" cy="625" r="5"/>
              </svg>

              <article class="sketch-element sketch-card sketch-ui-card" data-sketch-element="ui-wireframe" style="--delay:.05s">
                <h3>طراحی UI / وایرفریم</h3>
                <div class="ui-card-body">
                  <svg class="wire-thumb" viewBox="0 0 132 84" aria-hidden="true">
                    <rect x="2" y="2" width="128" height="80" rx="5"/>
                    <path d="M5 78 43 43l25 22 25-34 34 47M7 7l120 70M127 7 7 77"/>
                  </svg>
                  <div class="mini-copy-lines"><i></i><i></i><i></i><i></i></div>
                </div>
                <div class="wire-swatches"><i></i><i></i><i></i><span></span><span></span></div>
              </article>

              <article class="sketch-element sketch-card sketch-form-card" data-sketch-element="contact-form" style="--delay:.12s">
                <h3>فرم تماس</h3>
                <label><span>نام شما</span></label>
                <label><span>ایمیل شما</span></label>
                <button type="button">ارسال پیام</button>
              </article>

              <article class="sketch-element sketch-card sketch-chart-card" data-sketch-element="growth-chart" style="--delay:.19s">
                <h3>نمودار رشد</h3>
                <svg viewBox="0 0 170 126" aria-hidden="true">
                  <path class="chart-axis" d="M18 104H155M18 104V18"/>
                  <rect x="29" y="80" width="18" height="24"/><rect x="58" y="66" width="18" height="38"/>
                  <rect x="87" y="48" width="18" height="56"/><rect x="116" y="27" width="18" height="77"/>
                  <path class="chart-trend" d="M23 88 55 71 82 74 111 47 148 19"/>
                  <path class="chart-arrow" d="m134 18 14 1-3 14"/>
                </svg>
              </article>

              <article class="sketch-element sketch-card sketch-chat-card" data-sketch-element="chat" style="--delay:.26s">
                <h3>چت و پیام‌رسانی</h3>
                <div class="chat-window">
                  <span class="chat-avatar"></span>
                  <div class="chat-lines"><i></i><i></i></div>
                  <b>۵</b>
                </div>
              </article>

              <article class="sketch-element sketch-browser" data-sketch-element="desktop-browser" style="--delay:.33s">
                <div class="browser-topbar">
                  <span class="browser-dots"><i></i><i></i><i></i></span>
                  <b>W Webigram</b>
                </div>
                <div class="browser-nav-wire"><i></i><i></i><i></i><i></i><i></i></div>
                <div class="browser-content">
                  <div class="browser-hero-wire">
                    <svg class="browser-image-wire" viewBox="0 0 260 150" aria-hidden="true">
                      <rect x="2" y="2" width="256" height="146" rx="8"/>
                      <circle cx="204" cy="38" r="15"/>
                      <path d="M4 145 65 86l43 40 39-54 49 49 61-70v94"/>
                    </svg>
                    <div class="browser-hero-copy"><i></i><i></i><span></span><span></span><span></span><button type="button"></button></div>
                  </div>
                  <h4>خدمات ما</h4>
                  <div class="browser-services">
                    <div><b>▣</b><i></i><span></span></div>
                    <div><b>&lt;/&gt;</b><i></i><span></span></div>
                    <div><b>◈</b><i></i><span></span></div>
                  </div>
                  <h4 class="contact-title">ارتباط با ما</h4>
                  <div class="browser-contact">
                    <div class="message-wire"><span>پیام شما</span></div>
                    <div class="form-wire"><i></i><i></i><i></i><button type="button">ارسال</button></div>
                  </div>
                </div>
              </article>

              <article class="sketch-element sketch-phone" data-sketch-element="mobile-preview" style="--delay:.40s">
                <div class="phone-earpiece"></div>
                <div class="phone-brand-wire">W Webigram</div>
                <svg class="phone-image-wire" viewBox="0 0 150 94" aria-hidden="true">
                  <rect x="2" y="2" width="146" height="90" rx="7"/>
                  <circle cx="111" cy="24" r="10"/>
                  <path d="M4 90 38 58l27 22 21-31 29 28 33-40v53"/>
                </svg>
                <div class="phone-text-wire"><i></i><i></i><i></i></div>
                <button type="button"></button>
                <h4>خدمات ما</h4>
                <div class="phone-services-wire"><i></i><i></i></div>
                <h4>ارتباط با ما</h4>
                <div class="phone-input-wire"></div>
              </article>

              <article class="sketch-element sketch-card sketch-admin-card" data-sketch-element="admin-panel" style="--delay:.47s">
                <h3>پنل مدیریت</h3>
                <div class="admin-wire">
                  <div class="admin-sidebar"><i></i><i></i><i></i><i></i></div>
                  <div class="admin-chart-area"><span class="admin-pie"></span><svg viewBox="0 0 96 55"><path d="M5 46 25 32 42 39 63 18 90 7"/></svg></div>
                </div>
              </article>

              <svg class="sketch-element sketch-cursor" data-sketch-element="cursor" style="--delay:.54s" viewBox="0 0 90 102" aria-hidden="true">
                <path d="m8 5 9 72 16-19 17 34 14-8-18-33 27-4L8 5Z"/>
                <path class="cursor-rays" d="M15 5V0M2 19l-8-5M27 16l9-8"/>
              </svg>

              <div class="sketch-element sketch-pencil pencil-one" data-sketch-element="pencil-primary" style="--delay:.61s"><i></i></div>
              <div class="sketch-element sketch-pencil pencil-two" data-sketch-element="pencil-secondary" style="--delay:.68s"><i></i></div>

              <div class="sketch-element sketch-ruler" data-sketch-element="ruler" style="--delay:.75s">
                {Array.from({length:10}).map((_,i)=><span>{i+1}</span>)}
              </div>
            </div>
          </div>
          <div class="right">
            <header class="stage-header">
              <a class="brand" href="#sketch" data-jump="0"><svg class="brand-mark" viewBox="0 0 64 52"><path d="M4 7 16 45 28 14l8 31L60 7"/><path d="M7 9 17 41 28 17l8 25L57 9" opacity=".42" stroke-width="2"/></svg><span>Webigram</span></a>
              <nav class="nav" aria-label="منوی مرحله طرح اولیه">{nav.map(([label,step,key])=><a href={`#${step===0?'sketch':step===1?'color':'real'}`} data-jump={step} class={key==='home'?'current':''}>{label}</a>)}</nav>
            </header>
            <div class="copy">
              <h1>راهکار وب<br/>برای کسب‌وکار شما</h1>
              <p>ما وب‌سایت‌هایی مدرن، سریع و هدفمند طراحی می‌کنیم تا برند شما در فضای دیجیتال بدرخشد و رشد کند.<br/>از ایده تا اجرا، همراه مطمئن شما هستیم.</p>
              <div class="actions"><a href="#real" data-jump="2">شروع پروژه <span>←</span></a><a href="#color" data-jump="1">مشاهده نمونه‌کارها <span>←</span></a></div>
              <div class="benefits"><span><b>✎</b> طراحی اختصاصی</span><i></i><span><b>🚀</b> سئو و سرعت بالا</span><i></i><span><b>◉</b> پشتیبانی و همراهی</span></div>
            </div>
          </div>
        </section>

        <section class="slide slide-color" data-slide="1">
          <div class="visual"><img alt="نسخه رنگی طراحی وبیگرام" data-parts={`${base}slides/s2a.txt|${base}slides/s2b.txt`} /><span class="visual-mask"></span></div>
          <div class="right">
            <header class="stage-header">
              <a class="brand" href="#sketch" data-jump="0"><svg class="brand-mark" viewBox="0 0 64 52"><path d="M4 7 16 45 28 14l8 31L60 7"/><path d="M7 9 17 41 28 17l8 25L57 9" opacity=".55" stroke-width="2.5"/></svg><span>Webigram</span></a>
              <nav class="nav" aria-label="منوی مرحله طراحی رنگی">{nav.map(([label,step,key])=><a href={`#${step===0?'sketch':step===1?'color':'real'}`} data-jump={step} class={key==='services'?'current':''}>{label}</a>)}</nav>
            </header>
            <div class="copy">
              <h2>آنچه برای<br/><em>کسب‌وکار</em> شما می‌سازیم</h2>
              <p class="service-intro">خدماتی متناسب با نیاز واقعی کسب‌وکار شما؛<br/>ساده، کاربردی و قابل توسعه</p>
              <div class="service-list">{services.map(([title,icon])=><div class="service-item"><span>{title}</span><b>{icon}</b></div>)}</div>
            </div>
          </div>
        </section>

        <section class="slide slide-real" data-slide="2">
          <div class="visual"><img alt="نسخه واقعی و اجراشده وبیگرام" data-parts={`${base}slides/s3a.txt|${base}slides/s3b.txt`} /><span class="visual-mask"></span></div>
          <div class="right">
            <header class="stage-header">
              <a class="brand" href="#sketch" data-jump="0"><svg class="brand-mark" viewBox="0 0 64 52"><path d="M4 7 16 45 28 14l8 31L60 7"/><path d="M7 9 17 41 28 17l8 25L57 9" opacity=".55" stroke-width="2.5"/></svg><span>Webigram</span></a>
              <nav class="nav" aria-label="منوی مرحله محصول واقعی">{nav.map(([label,step,key])=><a href={`#${step===0?'sketch':step===1?'color':'real'}`} data-jump={step} class={key==='services'?'current':''}>{label}</a>)}</nav>
            </header>
            <div class="copy">
              <span class="badge">✦ ایده را به واقعیت تبدیل می‌کنیم ✦</span>
              <h2>برای ایده‌های<br/><em>شما</em> راه می‌سازیم</h2>
              <p>ایده‌های خوب نباید فقط در ذهن باقی بمانند.<br/>ما کمک می‌کنیم مسیر اجرای ایده‌تان روشن شود و قدم‌به‌قدم آن را به یک وب‌سایت، پنل یا ابزار کاربردی تبدیل می‌کنیم.</p>
            </div>
          </div>
        </section>
      </div>
    </div>
  </main>

  <div class="progress" aria-label="مراحل طراحی"><button class="active" data-jump="0" aria-label="طرح اولیه"></button><button data-jump="1" aria-label="طراحی رنگی"></button><button data-jump="2" aria-label="نسخه واقعی"></button></div>

  <script is:inline>
    const story=document.getElementById('story'),slides=[...document.querySelectorAll('[data-slide]')],dots=[...document.querySelectorAll('.progress button')],loader=document.getElementById('loader');
    const decode=async img=>{const parts=img.dataset.parts.split('|');const text=(await Promise.all(parts.map(p=>fetch(p).then(r=>{if(!r.ok)throw Error(p);return r.text()})))).join('').replace(/\s/g,'');const bin=atob(text),bytes=new Uint8Array(bin.length);for(let i=0;i<bin.length;i++)bytes[i]=bin.charCodeAt(i);img.src=URL.createObjectURL(new Blob([bytes],{type:'image/webp'}));await img.decode();};
    Promise.all([...document.querySelectorAll('img[data-parts]')].map(decode)).then(()=>loader.classList.add('done')).catch(()=>{loader.textContent='بارگذاری تصویرها ناموفق بود؛ صفحه را دوباره بارگذاری کنید.'});

    let current=-1,raf=0;
    const clamp=(value,min,max)=>Math.max(min,Math.min(max,value));
    const setStage=n=>{n=clamp(n,0,2);if(n===current)return;current=n;document.body.dataset.stage=n;slides.forEach((s,i)=>s.classList.toggle('active',i===n));dots.forEach((d,i)=>d.classList.toggle('active',i===n));document.documentElement.style.setProperty('--dot',n===0?'#171717':n===1?'#315cff':'#7b43ff');};

    const render=()=>{
      raf=0;
      const rect=story.getBoundingClientRect();
      const max=Math.max(1,story.offsetHeight-innerHeight);
      const y=clamp(-rect.top,0,max);
      const progress=(y/max)*2;

      slides.forEach((slide,index)=>{
        const cover=index<slides.length-1?clamp(progress-index,0,1):0;
        const inset=`inset(0 0 ${cover*100}% 0)`;
        slide.style.transform='none';
        slide.style.clipPath=inset;
        slide.style.webkitClipPath=inset;
        slide.style.zIndex=String(slides.length-index);
        slide.setAttribute('aria-hidden',Math.round(progress)!==index?'true':'false');
      });

      setStage(Math.round(progress));
    };

    const queueRender=()=>{if(!raf)raf=requestAnimationFrame(render)};
    addEventListener('scroll',queueRender,{passive:true});
    addEventListener('resize',queueRender);
    requestAnimationFrame(render);

    document.addEventListener('click',e=>{
      const el=e.target.closest('[data-jump]');
      if(!el)return;
      e.preventDefault();
      const n=Number(el.dataset.jump),max=Math.max(1,story.offsetHeight-innerHeight);
      const target=story.offsetTop+(max/2)*n;
      scrollTo({top:target,behavior:'smooth'});
    });
  </script>
</body>
</html>
